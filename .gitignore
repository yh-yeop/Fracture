# ========== Unity ==========

# Unity generated folders
/[Ll]ibrary/
**/[Ll]ibrary/         # 모든 하위 폴더의 Library 무시
/[Tt]emp/
**/[Tt]emp/            # 모든 하위 폴더의 Temp 무시
/[Oo]bj/
**/[Oo]bj/             # 모든 하위 폴더의 Obj 무시
/[Bb]uild/
**/[Bb]uild/           # 모든 하위 폴더의 Build 무시
/[Bb]uilds/
**/[Bb]uilds/          # 모든 하위 폴더의 Builds 무시
/[Ll]ogs/
**/[Ll]ogs/            # 모든 하위 폴더의 Logs 무시
/[Uu]ser[Ss]ettings/
**/[Uu]ser[Ss]ettings/ # 모든 하위 폴더의 UserSettings 무시
/[Mm]emoryCaptures/
**/[Mm]emoryCaptures/  # 모든 하위 폴더의 MemoryCaptures 무시
/[Rr]ecordings/
**/[Rr]ecordings/      # 모든 하위 폴더의 Recordings 무시

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio & Rider cache
.vs/
.gradle/

# Autogenerated solution/project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity crash/meta/temp files
*.pidb.meta
*.pdb.meta
*.mdb.meta
sysinfo.txt

# Builds & packages
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# ========== Python ==========

__pycache__/
*.py[cod]
venv/
.venv/
env/
ENV/
.ipynb_checkpoints/
.mypy_cache/
.pytest_cache/

# ========== Unity Editor temp files ========== 
*.utmp
